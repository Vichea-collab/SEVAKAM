# Public client-side runtime configuration.
# This file is bundled into the app. Do NOT put server secrets here.

# Backend API
API_BASE_URL=http://localhost:5050

# Mobile device backends
# iOS physical device usually needs your Mac hostname or LAN IP.
API_BASE_URL_IOS=http://YOUR-MAC.local:5050
# Android emulator can use localhost; the app rewrites it to 10.0.2.2 automatically.
API_BASE_URL_ANDROID=http://localhost:5050

# Google Maps client keys
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_FALLBACK_KEY
GOOGLE_MAPS_WEB_API_KEY=YOUR_GOOGLE_MAPS_WEB_KEY
GOOGLE_MAPS_ANDROID_API_KEY=YOUR_GOOGLE_MAPS_ANDROID_KEY
GOOGLE_MAPS_IOS_API_KEY=YOUR_GOOGLE_MAPS_IOS_KEY

# Firebase client config
FIREBASE_API_KEY=YOUR_FIREBASE_FALLBACK_API_KEY
FIREBASE_APP_ID=YOUR_FIREBASE_FALLBACK_APP_ID
FIREBASE_WEB_API_KEY=YOUR_FIREBASE_WEB_API_KEY
FIREBASE_WEB_APP_ID=YOUR_FIREBASE_WEB_APP_ID
FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET

# Platform-specific Firebase overrides
FIREBASE_ANDROID_API_KEY=YOUR_FIREBASE_ANDROID_API_KEY
FIREBASE_ANDROID_APP_ID=YOUR_FIREBASE_ANDROID_APP_ID
FIREBASE_IOS_API_KEY=YOUR_FIREBASE_IOS_API_KEY
FIREBASE_IOS_APP_ID=YOUR_FIREBASE_IOS_APP_ID
FIREBASE_IOS_CLIENT_ID=YOUR_FIREBASE_IOS_CLIENT_ID
FIREBASE_IOS_BUNDLE_ID=com.company.sevekam

# Optional web-only Firebase values
FIREBASE_MEASUREMENT_ID=
FIREBASE_WEB_CLIENT_ID=
FIREBASE_RECAPTCHA_V3_SITE_KEY=

# Debug / web App Check
FIREBASE_ENABLE_DEBUG_MOBILE_APP_CHECK=false
